# === Modo de conexao com TeamSpeak ===

# "clientquery" = TS3 desktop local (porta 25639)
# "serverquery" = conexao direta ao servidor TS (porta 10011)
TS_MODE=clientquery

# --- ClientQuery (quando TS_MODE=clientquery) ---
TS_APIKEY=YOUR-API-KEY-HERE

# --- ServerQuery (quando TS_MODE=serverquery) ---
TS_HOST=crusaders.expto.com.br
TS_QUERY_PORT=10011
TS_QUERY_USER=serveradmin
TS_QUERY_PASS=your-password-here
TS_VIRTUAL_SERVER=1

# --- Bridge (quando TS_MODE=bridge) ---
BRIDGE_URL=http://ts3bridge:8080

# === Bot ===
# UID do CrusaderBot no TeamSpeak (para comunicacao com o bot)
BOT_UID=JtyuT0YIadDhysblVvprGK/0Ces=

# === Dashboard ===
WEB_PORT=3000
